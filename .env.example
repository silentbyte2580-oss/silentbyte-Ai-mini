# ─── SilentByte AI Mini Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Bot name displayed in terminal
BOT_NAME=SilentByte AI

# Set to false to disable AI chat responses (bot will still connect)
CHATBOT=true

# Session storage path
SESSION_PATH=./session

# Max retries for pairing code requests
MAX_RETRIES=3

# AssemblyAI key for voice transcription (already set in database/apis.js)
# ASSEMBLYAI_API_KEY=your_key_here
